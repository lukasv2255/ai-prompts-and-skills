{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": ["Bash(*)"],
    "deny": [],
    "ask": [
      "Bash(rm -rf*)",
      "Bash(rm -r*)",
      "Bash(sudo rm*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(chmod -R 777*)",
      "Bash(dd *)",
      "Bash(mkfs*)"
    ]
  }
}
