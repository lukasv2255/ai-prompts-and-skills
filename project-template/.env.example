# Vzor env proměnných — zkopíruj na `.env` a doplň reálné hodnoty.
# `.env` je gitignored, tenhle soubor (.env.example) se commituje.

# --- AI ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Telegram (pokud bot) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Web/API ---
# PORT=8090

# --- DB ---
# DATABASE_URL=
